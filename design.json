{
  "cds_version": "1.0",
  "name": "ccplugin-voice-input",
  "type": "plugin",
  "input_patterns": [
    {
      "type": "slash_command",
      "commands": [
        "/run-voice"
      ]
    }
  ],
  "output_patterns": [
    {
      "type": "terminal_text",
      "max_lines": 5
    }
  ],
  "lifecycle": {
    "preflight": {
      "required_tools": [
        "sox"
      ],
      "required_secrets": [],
      "required_mcp": []
    }
  },
  "error_handling": {
    "retry_network": false,
    "max_retries": 0,
    "fallback": "apple built-in speech recognition"
  }
}
